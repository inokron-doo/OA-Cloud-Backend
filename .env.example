PREDICTION_SERVICE_URL=http://127.0.0.1:8015
PREDICTION_SERVICE_API_KEY=change-me

# Allowed CORS origins (comma-separated). Required when the browser talks to the
# backend cross-origin (e.g. local dev on the Vite server, or a deployed frontend
# on a different host). In the Docker deploy the frontend nginx proxies /api to the
# backend same-origin, so CORS is not exercised there.
# - Unset: defaults to localhost dev origins (5173, 3000, localhost).
# - "*":   wildcard, but credentials are then disabled (cannot combine per spec).
# Example for production:
# CORS_ORIGINS=https://farm.example.com
CORS_ORIGINS=
